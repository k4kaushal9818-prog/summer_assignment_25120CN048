# Program to find sum and average of array

arr = []

n = int(input("Enter number of elements: "))

# Input array elements
for i in range(n):
    element = int(input("Enter element: "))
    arr.append(element)

# Finding sum
total = sum(arr)

# Finding average
average = total / n

# Displaying results
print("Sum of array elements is:", total)
print("Average of array elements is:", average)
