# Input array
arr = list(map(int, input("Enter elements: ").split()))

# Bubble Sort
n = len(arr)

for i in range(n):
    for j in range(0, n - i - 1):
        if arr[j] > arr[j + 1]:
            # Swap elements
            arr[j], arr[j + 1] = arr[j + 1], arr[j]

# Display sorted array
print("Sorted array:", arr)
