# Program to check prime number using function

def check_prime(num):
    if num <= 1:
        return False
    
    for i in range(2, num):
        if num % i == 0:
            return False
    
    return True

# Taking input from user
number = int(input("Enter a number: "))

# Calling function
if check_prime(number):
    print("The number is prime")
else:
    print("The number is not prime")
