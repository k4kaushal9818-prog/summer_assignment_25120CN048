# Program to find maximum using function

def find_max(a, b):
    if a > b:
        return a
    else:
        return b

# Taking input from user
num1 = int(input("Enter first number: "))
num2 = int(input("Enter second number: "))

# Calling function
maximum = find_max(num1, num2)

# Displaying result
print("Maximum number is:", maximum)
