# Program to move zeroes to the end of an array

numbers = [0, 1, 0, 3, 12, 0, 5]

result = []

# Add all non-zero elements
for num in numbers:
    if num != 0:
        result.append(num)

# Count zeroes and add them at the end
zero_count = numbers.count(0)
for i in range(zero_count):
    result.append(0)

print("Array after moving zeroes to the end:", result)
