# Program to print character pyramid pattern

n = 5

for i in range(1, n + 1):
    # Print spaces
    for j in range(n - i):
        print(" ", end="")
    
    # Print increasing characters
    for j in range(i):
        print(chr(65 + j), end="")
    
    # Print decreasing characters
    for j in range(i - 2, -1, -1):
        print(chr(65 + j), end="")
    
    print()
