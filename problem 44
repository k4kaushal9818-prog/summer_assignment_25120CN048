# Program to find factorial using function

def factorial(num):
    fact = 1
    
    for i in range(1, num + 1):
        fact = fact * i
    
    return fact

# Taking input from user
number = int(input("Enter a number: "))

# Calling function
result = factorial(number)

# Displaying result
print("Factorial of", number, "is:", result)
